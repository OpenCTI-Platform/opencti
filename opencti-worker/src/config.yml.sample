---
opencti:
  url: 'http://localhost:8080'
  token: 'ChangeMe'
  json_logging: true

# Optional: route STIX bundle ingestion to opencti-ng instead of GraphQL
# opencti_ng:
#   url: 'http://localhost:4100'
#   token: 'ChangeMe'

worker:
  log_level: 'info'
  telemetry_enabled: false
  objects_max_refs: 0