    {
      "id": "intrusion-set--18854f55-ac7c-4634-bd9a-352dd07613b7",
      "type": "intrusion-set",
      "spec_version": "2.1",
      "name": "APT41",
      "aliases": ["Winnti"],
      "labels": ["intrusion-set"],
      "description": "[APT41](https://attack.mitre.org/groups/G0096) is a group that carries out Chinese state-sponsored espionage activity in addition to financially motivated activity. [APT41](https://attack.mitre.org/groups/G0096) has been active since as early as 2012. The group has been observed targeting healthcare, telecom, technology, and video game industries in 14 countries.(Citation: FireEye APT41 Aug 2019)",
      "created": "2019-09-23T13:43:36.945Z",
      "modified": "2019-10-14T21:52:59.301Z",
      "x_opencti_id": "82316ffd-a0ec-4519-a454-6566f8f5676c",
      "created_by_ref": "identity--c78cb6e5-0c4b-4611-8297-d1b8b55e40b5",
      "object_marking_refs": ["marking-definition--fa42a846-8d90-4e51-bc29-71d5b4802168"],
      "external_references": [
        {
          "source_name": "FireEye APT41 Aug 2019",
          "description": "Fraser, N., et al. (2019, August 7). Double DragonAPT41, a dual espionage and cyber crime operation APT41. Retrieved September 23, 2019.",
          "url": "https://content.fireeye.com/apt-41/rpt-apt41"
        },
        {
          "source_name": "mitre-attack",
          "url": "https://attack.mitre.org/groups/G0096",
          "external_id": "G0096"
        }
      ]
    },
    {
      "id": "attack-pattern--2fc04aa5-48c1-49ec-919a-b88241ef1d17",
      "type": "attack-pattern",
      "spec_version": "2.1",
      "x_opencti_external_id": "T1368",
      "name": "Spear phishing messages with malicious links",
      "labels": ["attack-pattern"],
      "description": "This technique has been deprecated. Please see ATT&CK's Initial Access and Execution tactics for replacement techniques.\n\nEmails with text only phishing messages do not contain any attachments or links to websites. They are designed to get a user to take a follow on action such as calling a phone number or wiring money. They can also be used to elicit an email response to confirm existence of an account or user. (Citation: Paypal Phone Scam)",
      "created": "2017-12-14T16:46:06.044Z",
      "modified": "2018-10-17T00:14:20.652Z",
      "created_by_ref": "identity--c78cb6e5-0c4b-4611-8297-d1b8b55e40b5",
      "object_marking_refs": ["marking-definition--fa42a846-8d90-4e51-bc29-71d5b4802168"],
      "kill_chain_phases": [
