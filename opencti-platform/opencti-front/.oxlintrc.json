{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": [
    "import",
    "typescript",
    "react",
    "eslint",
    "jsx-a11y",
    "jest",
    "vitest",
    "react-perf"
  ],
  "categories": {
    "correctness": "allow"
  },
  "env": {
    "browser": true,
    "jest": true
  },
  "rules": {
    "max-classes-per-file": [
      "error",
      2
    ],
    "no-unused-vars": [
      "error",
      {
        "argsIgnorePattern": "^_",
        "varsIgnorePattern": "^_",
        "caughtErrorsIgnorePattern": "^_"
      }
    ]
  }
}